---
const today = new Date();
---

<footer>
	&copy; {today.getFullYear()} Abhinav Kayastha. All rights reserved.
	<div class="social-links">
		<a href="https://github.com/abhinav-kayastha/personal-website" target="_blank">
			<span class="sr-only">Go to my GitHub</span>
			<svg viewBox="0 0 16 16" aria-hidden="true" width="32" height="32" astro-icon="social/github"
				><path
					fill="currentColor"
					d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
				></path></svg
			>
		</a>
	</div>
</footer>
<style>
	@keyframes slideUp {
		from {
			opacity: 0;
			transform: translateY(20px);
		}
		to {
			opacity: 1;
			transform: translateY(0);
		}
	}

	footer {
		padding: 3em 1em 2em 1em;
		background: var(--bg-secondary);
		border-top: 2px solid rgba(88, 166, 255, 0.2);
		color: var(--text-secondary);
		text-align: center;
		margin-top: 4em;
		animation: slideUp 0.8s ease-out;
	}

	footer a {
		color: var(--text-secondary);
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		position: relative;
	}

	footer a::before {
		content: '';
		position: absolute;
		bottom: -2px;
		left: 0;
		width: 0;
		height: 2px;
		background: linear-gradient(90deg, #58a6ff, #79c0ff);
		transition: width 0.3s ease;
	}

	footer a:hover {
		color: #58a6ff;
	}

	footer a:hover::before {
		width: 100%;
	}

	.social-links {
		display: flex;
		justify-content: center;
		gap: 2em;
		margin-top: 1.5em;
	}

	.social-links a {
		text-decoration: none;
		color: var(--text-secondary);
		display: flex;
		align-items: center;
		transition: all 0.3s cubic-bezier(0.34, 1.56, 0.64, 1);
		position: relative;
	}

	.social-links a:hover {
		color: #58a6ff;
		transform: translateY(-5px) scale(1.2);
	}

	.social-links a svg {
		width: 32px;
		height: 32px;
		transition: all 0.3s ease;
	}

	.social-links a:hover svg {
		filter: drop-shadow(0 0 10px rgba(88, 166, 255, 0.6));
	}
</style>
